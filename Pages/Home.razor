@page "/"
@inject HttpClient Http

<PageTitle>Home</PageTitle>

<div class="hero">
    <div class="name">
        <h1 class="capital">Personalized healthcare, <br> Powered by <em>you</em></h1>
        
        <h3>Welcome To <strong>Paramedy</strong></h3>

        <div class="btn-area">
            <button class="secondary">
                Get Started
            </button> 
        </div>
    </div>
</div>

@if (_card == null)
{
    <p>Loading Cards...</p>
}
else
{
    <div class="grid">
        @foreach (var trail in _trails)
        {
            <Card Card="card" />
        }
    </div>
}

@code {
    private IEnumerable<Card>? _card;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _card = await Http.GetFromJsonAsync <IEnumerable<Card>>("card/card-data.json");
        }
        catch (HttpRquestException ex)
        {
            Console.WriteLine($"There was a problem loading the card data: {ex.Message}");
        }
    }
}